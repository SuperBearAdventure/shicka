{
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "lib": ["esnext"],
    "module": "nodenext",
    "moduleDetection": "force",
    "noUncheckedIndexedAccess": false,
    "outDir": "bin",
    "rootDir": "src",
    "skipLibCheck": true,
    "target": "esnext",
    "verbatimModuleSyntax": true
  }
}
